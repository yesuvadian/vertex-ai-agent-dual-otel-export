# Multi-Destination Forwarder Configuration
# Copy this file to .env and update with your values

# ============================================
# GCP Configuration
# ============================================
GCP_PROJECT_ID=agentic-ai-integration-490716
PUBSUB_SUBSCRIPTION=all-customers-logs-sub

# ============================================
# Destination 1: Portal26 OTEL (Real-Time Analytics)
# ============================================
# Enable/Disable: Leave empty to disable
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-tenant1.portal26.in:4318
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic dGl0YW5pYW06aGVsbG93b3JsZA==
PORTAL26_TENANT_ID=tenant1
PORTAL26_USER_ID=relusys_terraform
OTEL_SERVICE_NAME=gcp-vertex-monitor

# Portal26 Batching
PORTAL26_BATCH_SIZE=20
PORTAL26_BATCH_TIMEOUT=5

# ============================================
# Destination 2: AWS Kinesis (Streaming)
# ============================================
# Enable/Disable: Leave empty to disable
KINESIS_STREAM_NAME=gcp-logs-stream
AWS_REGION=us-east-1

# Kinesis Batching
KINESIS_BATCH_SIZE=100

# ============================================
# Destination 3: AWS S3 (Archival)
# ============================================
# Enable/Disable: Leave empty to disable
S3_BUCKET_NAME=gcp-logs-archive
S3_PREFIX=gcp-logs/
# AWS_REGION is shared with Kinesis above

# S3 Batching
S3_BATCH_SIZE=500

# ============================================
# Routing Strategy Configuration
# ============================================

# Small Log Threshold (bytes)
# Logs smaller than this go to Portal26 for real-time analytics
# Default: 102400 (100 KB)
SMALL_LOG_THRESHOLD=102400

# Large Log Threshold (bytes)
# Logs larger than this go to S3 for archival
# Default: 1048576 (1 MB)
LARGE_LOG_THRESHOLD=1048576

# High Volume Threshold (logs per minute)
# When traffic exceeds this, route to Kinesis instead of Portal26
# Default: 100
HIGH_VOLUME_THRESHOLD=100

# ============================================
# Routing Priority
# ============================================
# 1. Very large logs (> LARGE_LOG_THRESHOLD) → S3
# 2. High volume (> HIGH_VOLUME_THRESHOLD) → Kinesis
# 3. Medium logs (SMALL < size < LARGE) → Kinesis
# 4. Small logs (< SMALL_LOG_THRESHOLD) → Portal26
# 5. Fallback: Kinesis → S3 → Drop

# ============================================
# Operational Configuration
# ============================================
HEALTH_CHECK_INTERVAL=60
AGENT_TYPE=aws-ecs-multi-dest

# ============================================
# Example Configurations for Different Use Cases
# ============================================

# --- Real-Time Focus (More to Portal26) ---
# SMALL_LOG_THRESHOLD=512000        # 500 KB
# LARGE_LOG_THRESHOLD=2097152       # 2 MB
# HIGH_VOLUME_THRESHOLD=200         # Higher tolerance

# --- Streaming Focus (More to Kinesis) ---
# SMALL_LOG_THRESHOLD=51200         # 50 KB
# LARGE_LOG_THRESHOLD=524288        # 500 KB
# HIGH_VOLUME_THRESHOLD=50          # Lower threshold

# --- Cost Focus (More to S3) ---
# SMALL_LOG_THRESHOLD=10240         # 10 KB
# LARGE_LOG_THRESHOLD=102400        # 100 KB
# HIGH_VOLUME_THRESHOLD=20          # Aggressive

# --- Portal26 Only (Disable others) ---
# KINESIS_STREAM_NAME=
# S3_BUCKET_NAME=
# SMALL_LOG_THRESHOLD=10485760      # 10 MB (very high)

# --- Kinesis + S3 Only (Disable Portal26) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=
# SMALL_LOG_THRESHOLD=524288        # 500 KB
# LARGE_LOG_THRESHOLD=5242880       # 5 MB

# --- S3 Only (Archival/Compliance) ---
# OTEL_EXPORTER_OTLP_ENDPOINT=
# KINESIS_STREAM_NAME=
# SMALL_LOG_THRESHOLD=0             # Everything to S3

# ============================================
# Performance Tuning
# ============================================

# Increase batch sizes for higher throughput (but higher latency)
# PORTAL26_BATCH_SIZE=50
# KINESIS_BATCH_SIZE=500
# S3_BATCH_SIZE=1000

# Decrease batch timeouts for lower latency (but more API calls)
# PORTAL26_BATCH_TIMEOUT=2

# ============================================
# Notes
# ============================================
# - All size thresholds are in BYTES
# - Volume threshold is logs per MINUTE
# - Leave destination configs empty to disable that destination
# - At least one destination must be enabled
# - Changes require container restart
# - For local testing, use .env file
# - For AWS ECS, use environment variables or Secrets Manager
