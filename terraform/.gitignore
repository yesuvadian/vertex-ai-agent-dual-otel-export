# Terraform state files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform variable files (may contain sensitive data)
terraform.tfvars
*.auto.tfvars
*.auto.tfvars.json

# Terraform directory
.terraform/
.terraform.lock.hcl

# Crash log files
crash.log
crash.*.log

# Temporary files
temp_*.json
*.tmp

# Environment files
.env
.env.*
!.env.example

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json
