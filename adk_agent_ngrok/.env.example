# Google Cloud Configuration
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OTEL Export to ngrok → Local Collector → Portal26
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-ngrok-url.ngrok-free.dev
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-encoded-credentials>

# Telemetry Configuration
OTEL_INSTRUMENTATION_GENAI_CAPTURE_MESSAGE_CONTENT=true
OTEL_SERVICE_NAME=portal26GCPLocal
OTEL_PROPAGATORS=tracecontext,baggage

# Resource Attributes
OTEL_RESOURCE_ATTRIBUTES=portal26.user.id=your-user,portal26.tenant_id=your-tenant,service.version=1.0,deployment.environment=agent-ngrok,agent.type=ngrok-export

# Agent Engine Settings
GOOGLE_CLOUD_AGENT_ENGINE_ENABLE_TELEMETRY=true
