# Portal26 Backend Configuration
PORTAL26_ENDPOINT=https://otel.portal26.ai/v1/traces
PORTAL26_USERNAME=your_username
PORTAL26_PASSWORD=your_password
PORTAL26_TIMEOUT=30

# GCP Configuration
GCP_PROJECT=portal26-telemetry-prod
GCP_LOCATION=us-central1

# Redis (optional - for distributed deduplication)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Deduplication Cache TTL (seconds)
DEDUP_CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO

# Cloud Run Port
PORT=8080
