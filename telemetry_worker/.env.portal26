# Portal26 OTEL Configuration
# Based on provided Portal26 environment variables

# Portal26 Endpoint (OTLP HTTP)
PORTAL26_ENDPOINT=https://otel-tenant1.portal26.in:4318/v1/traces

# Basic Authentication
# Base64 decoded: titaniam:helloworld
PORTAL26_USERNAME=titaniam
PORTAL26_PASSWORD=helloworld

# OTEL Resource Attributes
OTEL_RESOURCE_ATTRIBUTES=portal26.user.id=relusys,portal26.tenant_id=tenant1

# Log User Prompts
OTEL_LOG_USER_PROMPTS=1

# OTEL Protocol
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Export Intervals (milliseconds)
OTEL_METRIC_EXPORT_INTERVAL=1000
OTEL_LOGS_EXPORT_INTERVAL=500

# Timeout
PORTAL26_TIMEOUT=30

# Redis (optional)
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Dedup Cache TTL
DEDUP_CACHE_TTL=3600

# Logging
LOG_LEVEL=INFO
