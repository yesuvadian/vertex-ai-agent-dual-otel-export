GOOGLE_CLOUD_PROJECT=your-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# Optional: Use API key instead of Application Default Credentials
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLOUD_API_KEY=your-api-key-here

# OpenTelemetry Configuration - Portal26
OTEL_SERVICE_NAME=ai-agent
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-endpoint.com:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic your-base64-encoded-credentials

# Exporters
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Resource Attributes
OTEL_RESOURCE_ATTRIBUTES=portal26.user.id=your-user,portal26.tenant_id=your-tenant,service.version=1.0,deployment.environment=dev

# Export Intervals
OTEL_METRIC_EXPORT_INTERVAL=1000
OTEL_LOGS_EXPORT_INTERVAL=500

# Sampling
OTEL_TRACES_SAMPLER=traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# Additional Settings
OTEL_LOG_USER_PROMPTS=1

# Agent Configuration
# AGENT_MODE options: manual, adk, both
AGENT_MODE=manual

# Individual agent toggles (alternative to AGENT_MODE)
ENABLE_MANUAL_AGENT=true
ENABLE_ADK_AGENT=false
